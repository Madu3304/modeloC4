@startuml c4_container_nivel2

!include https://raw.githubusercontent.com/RicardoNiepel/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()

title Diagrama de Containers (Nível 2) - Sistema de Gestão SAMU

' Pessoas
Person(admin, "Administrador", "Gerencia usuários, relatórios e dashboards")

Person(enfermeiro, "Enfermeiro/Técnico", "Registra atendimentos e consulta informações")

' Sistemas externos
System_Ext(prefeitura, "Banco da Prefeitura", "Integração de dados municipais")

System_Ext(gps, "Serviço de GPS", "Puxa a localização automática")

System_Ext(pdf_service, "Serviço PDF", "Geração de relatórios PDF")

' Containers
System_Boundary(s1, "Sistema de Gestão SAMU") {

    Container(app_mobile, "Aplicativo Mobile", "Flutter/Dart", "Registro de atendimentos e sincronização offline")

    Container(web_dashboard, "Dashboard Web", "Flutter/Dart", "Painel administrativo e métricas")

    Container(api_backend, "API Backend", "Python/FastAPI", "Autenticação, regras de negócio e integração")

    ContainerDb(sqlite_local, "Banco Local", "SQLite", "Armazena dados offline")

    ContainerDb(postgres, "Banco Central", "PostgreSQL", "Armazena fichas, usuários e logs")

    Container(auth_service, "Serviço de Autenticação", "JWT", "Controle de login e permissões")

    Container(log_service, "Serviço de Logs", "Python", "Auditoria e rastreabilidade")
}

' Relacionamentos
Rel(admin, web_dashboard, "Acessa dashboards e relatórios")

Rel(enfermeiro, app_mobile, "Registra atendimentos")

Rel(app_mobile, sqlite_local, "Salva dados offline")

Rel(app_mobile, api_backend, "Sincroniza dados", "HTTPS")

Rel(web_dashboard, api_backend, "Consulta e gerencia dados", "HTTPS")

Rel(api_backend, postgres, "Lê e grava informações")

Rel(api_backend, auth_service, "Valida autenticação")

Rel(api_backend, log_service, "Registra logs")

Rel(api_backend, prefeitura, "Integra dados municipais", "HTTPS/API")

Rel(api_backend, gps, "Obtém localização")

Rel(api_backend, pdf_service, "Gerar relatórios PDF")

SHOW_LEGEND()

@enduml
